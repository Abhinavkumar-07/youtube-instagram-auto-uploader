# Google Drive folder ID containing your videos (from the folder's URL)
DRIVE_FOLDER_ID=

# Groq API key for generating title/description/tags (free tier: console.groq.com/keys)
GROQ_API_KEY=

# Describe your content type for better AI-generated titles/captions
# Examples: "podcast clips", "gaming highlights", "cooking tutorials", "vlog content"
CONTENT_DESCRIPTION=short-form video content

# Your timezone (IANA name)
TIMEZONE=Asia/Kolkata

# Daily go-live times, 24hr HH:MM, in TIMEZONE above
# Slot A default: 5:30 PM IST = 8:00 AM ET = 1:00 PM UK
# Slot B default: 9:30 PM IST = 12:00 PM ET = 5:00 PM UK
SLOT_A_TIME=17:30
SLOT_B_TIME=21:30

# Optional: category ID for YouTube (22 = People & Blogs, good for podcast clips)
YOUTUBE_CATEGORY_ID=22

# Meta / Instagram Graph API (see README for how to get these)
META_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# How many days to keep published entries in publish_queue.json before pruning (default: 30)
QUEUE_PRUNE_DAYS=30